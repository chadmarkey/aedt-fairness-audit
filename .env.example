# Optional: control where Hugging Face caches the SBERT model.
# Default behavior writes to ~/.cache/huggingface; set this to redirect.
# HF_HOME=./hf_cache

# Optional: disable telemetry from sentence-transformers / torch.
# TRANSFORMERS_NO_ADVISORY_WARNINGS=1
# HF_HUB_DISABLE_TELEMETRY=1

# If you build sentiment/llm_judge.py support (not in this initial release),
# the wrappers would expect one of these:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
